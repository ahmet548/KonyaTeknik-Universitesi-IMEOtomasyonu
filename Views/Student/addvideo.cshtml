<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KTUN | İşletmede Mesleki Eğitim Öğrenci Sayfası</title>
    <link rel="shortcut icon" href="~/img/logo_2.ico">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <meta name="keywords" content="moodle, Konya Teknik Üniversitesi İşletmede Mesleki Eğitim: Siteye giriş yap">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="~/styles/custom/css/KTUN-StudentPage.css?v=@DateTime.Now.Ticks">
    <!-- Video.js CSS -->
    <link href="https://vjs.zencdn.net/7.20.3/video-js.css" rel="stylesheet" />
</head>

<body>
    <!-- Navbar -->
    <nav class="navbar navbar-ktun navbar-expand-lg">
        <div class="container-fluid">
            <!-- Logo ve Üniversite İsmi -->
            <a class="navbar-brand d-flex align-items-center" href="#">
                <div class="ktun-logo">
                    <img src="https://lms.ktun.edu.tr/pluginfile.php/1/theme_remui/loginpanellogo/1756726302/logo.png"
                        style="height: 50px;" alt="KTUN Logo">
                </div>
            </a>

            <!-- Mobil menü butonu -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent"
                aria-controls="navbarContent" aria-expanded="false" aria-label="Menüyü aç/kapat">
                <i class="fas fa-bars"></i>
            </button>

            <!-- Menü içeriği -->
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link main-nav-link active" href="#">Ana Sayfa</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link main-nav-link" href="#">Kontrol Paneli</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link main-nav-link" href="#">Staj Defteri</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link main-nav-link" href="#">Mazeret Bildir</a>
                    </li>
                </ul>

                <!-- Bildirim ve Mesaj İkonları -->
                <div class="d-flex align-items-center me-4">
                    <!-- Bildirim İkonu -->
                    <div class="dropdown">
                        <a class="notification-icon" href="#" role="button" id="notificationDropdown"
                            data-bs-toggle="dropdown" aria-expanded="false">
