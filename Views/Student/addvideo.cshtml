    <!-- Yan Menü -->
    <div id="sidebar" class="sidebar">
        <div class="sidebar-header">
            <h5 class="sidebar-title">Videolarım</h5>
            <button class="close-sidebar" id="closeSidebar">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="sidebar-content">
            @{
                var videos = ViewBag.Videos as List<IMEAutomationDBOperations.Models.Video>;
            }
            @if (videos != null && videos.Any())
            {
                <ul class="sidebar-menu" id="videosList">
                    @foreach (var video in videos)
                    {
                        <a class="sidebar-menu-item @(ViewBag.CurrentVideo?.VideoID == video.VideoID ? "active" : "")"
                            href="/Student/AddVideoPage?videoId=@video.VideoID" style="cursor: pointer;"
                            data-video-id="@video.VideoID">
                            <div class="video-item">
                                <div class="video-title">@video.Title</div>
                                @if (ViewBag.CurrentVideo?.VideoID == video.VideoID)
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                        class="bi bi-arrow-clockwise" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd"
                                            d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z" />
                                        <path
                                            d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466" />
                                    </svg>
                                }
                            </div>
                        </a>
                    }
                </ul>
            }
            else
            {
                <div class="empty-videos">
                    <p>Henüz video bulunmamaktadır</p>
                </div>
            }
        </div>
    </div>

    <!-- Menü Açma Butonu -->
    <button class="menu-toggle" id="menuToggle">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-arrow-right"
            viewBox="0 0 16 16">
            <path fill-rule="evenodd"
                d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8" />
        </svg>
    </button>

    <div class="main-content">
        <div class="file-path">
            <a>Staj Defteri:0_<span>@ViewBag.Department</span></a>
            <span>/</span>
            <span>
                @if (ViewBag.IsEditMode && ViewBag.CurrentVideo != null)
                {
                    <span>@ViewBag.CurrentVideo.UploadDate.ToString("dd MMMM yyyy") tarihli</span>
                    <span class="video-title-path">(@ViewBag.CurrentVideo.Title)</span>
                }
                else
                {
                    <span>@DateTime.Now.ToString("dd MMMM yyyy") tarihli</span>
                    <span class="video-title-path"></span>
                }
            </span>
        </div>

        <!-- Header Section -->
        <header class="page-header">
            <div class="header-overlay"></div>
            <div class="header-background">
                <div class="header-content">
                    <div class="header-info">
                        <span class="department-title">@ViewBag.Department</span>
                        <span>@ViewBag.Title<span>_Staj Defteri</span></span>
                        <div class="header-details">
                            <div class="detail-item">
                                <div class="user-initials" style="scale: 0.7;">
                                    @if (ViewBag.Supervisor != null &&
                                                                        !string.IsNullOrEmpty(ViewBag.supervisor.User.FirstName) &&
                                                                        !string.IsNullOrEmpty(ViewBag.supervisor.User.LastName))
                                    {
                                        @($"{ViewBag.supervisor.User.FirstName[0]}{ViewBag.supervisor.User.LastName[0]}")
                                    }
                                    else
                                    {
                                        @("S")
                                    }
                                </div>
                                <span>@(ViewBag.Supervisor?.FirstName ?? "Supervisor") @(ViewBag.Supervisor?.LastName ??
                                                                        "")</span>
                            </div>
                            <div class="detail-item">
                                <div class="user-initials" style="scale: 0.7;">
                                    @if (ViewBag.Company != null && !string.IsNullOrEmpty(ViewBag.Company.CompanyName))
                                    {
                                        var companyName = ViewBag.Company.CompanyName.Trim();
                                        var words = companyName.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);

                                        if (words.Length >= 2)
                                        {
                                            @($"{words[0][0]}{words[1][0]}")
                                        }
                                        else
                                        {
                                            @companyName[0]
                                        }
                                    }
                                    else
                                    {
                                        @("İ")
                                    }
                                </div>
                                <span>@(ViewBag.Company?.CompanyName ?? "İşletme Bilgisi Yok")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- Bootstrap Icons -->
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        
        <div class="add-video-container" style="margin: 20px 7.5% 60px 7.5%; width: calc(100% - 15%); max-width: none;">

            <!-- Header -->
            <div class="d-flex align-items-center mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="35" height="35" fill="currentColor" class="bi bi-camera-video me-3" style="color: black;" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M0 5a2 2 0 0 1 2-2h7.5a2 2 0 0 1 1.983 1.738l3.11-1.382A1 1 0 0 1 16 4.269v7.462a1 1 0 0 1-1.406.913l-3.111-1.382A2 2 0 0 1 9.5 13H2a2 2 0 0 1-2-2zm11.5 5.175 3.5 1.556V4.269l-3.5 1.556zM2 4a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h7.5a1 1 0 0 0 1-1V5a1 1 0 0 0-1-1z"></path>
                </svg>
                <h2 class="m-0" style="color: #343a40; font-weight: 600; font-size: 1.5rem;">
                    @if (ViewBag.IsEditMode != null && ViewBag.IsEditMode && ViewBag.CurrentVideo != null)
                    {
                        @($"{ViewBag.CurrentVideo.UploadDate.ToString("dd MMMM yyyy")} tarihli ({ViewBag.CurrentVideo.Title})")
                    }
                    else
                    {
                        @($"{DateTime.Now.ToString("dd MMMM yyyy")} tarihli")
                    }
                </h2>
            </div>

            <!-- Status Badge -->
            <div class="mb-4">
                <span class="border rounded px-3 py-1" style="font-size: 0.8rem; color: #495057; border-color: #dee2e6 !important;">Tamamladım</span>
            </div>

            <!-- Dates -->
            <div class="mb-5 pb-4 border-bottom" style="font-size: 0.9rem; color: #495057;">
                <div class="mb-1"><span style="font-weight: 600;">Açıldı:</span> @(ViewBag.Internship?.StartDate != null ? ViewBag.Internship.StartDate.ToString("dddd, dd MMMM yyyy, h:mm tt", new System.Globalization.CultureInfo("tr-TR")) : "Belirtilmedi")</div>
                <div><span style="font-weight: 600;">Son tarih:</span> @(ViewBag.Internship?.EndDate != null ? ViewBag.Internship.EndDate.ToString("dddd, dd MMMM yyyy, h:mm tt", new System.Globalization.CultureInfo("tr-TR")) : "Belirtilmedi")</div>
            </div>

            <!-- Submission Box -->
            <div class="bg-white border rounded p-4 shadow-sm" style="border-color: #dee2e6 !important;">
                
                <div class="d-flex justify-content-between align-items-center mb-4" style="cursor: pointer;" data-bs-toggle="collapse" data-bs-target="#submissionForm" aria-expanded="true" aria-controls="submissionForm" onclick="const icon = this.querySelector('i'); icon.style.transform = icon.style.transform === 'rotate(-90deg)' ? 'rotate(0deg)' : 'rotate(-90deg)';">
                    <h5 class="m-0 fw-bold" style="font-size: 1.1rem; color: #343a40;">Gönderim ekle</h5>
                    <i class="bi bi-chevron-down text-muted" style="font-size: 1.2rem; transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); display: inline-block;"></i>
                </div>

                <div class="collapse show" id="submissionForm">
                    <form method="post" action="/Student/UploadVideo" enctype="multipart/form-data">
                        <div class="row mb-4">
                        <div class="col-md-3">
                            <p class="text-muted m-0" style="font-size: 0.9rem;">Dosya gönderimleri</p>
                        </div>
                        <div class="col-md-9">
                            
                            <!-- Filemanager Wrapper -->
                            <div class="border rounded" style="background-color: #fff; border-color: #dee2e6 !important;">
                                <!-- Toolbar -->
                                <div class="d-flex justify-content-between p-2 border-bottom" style="background-color: #fff; border-color: #dee2e6 !important;">
                                    <div class="d-flex gap-2">
                                        <button type="button" class="btn btn-sm btn-light border-0 bg-white text-muted" title="Dosyalar"><i class="bi bi-folder" style="font-size:1.1rem;"></i> Dosyalar</button>
                                        <button type="button" class="btn btn-sm btn-light border-0 bg-white text-muted" title="Ekle" onclick="document.getElementById('videoFile').click()"><i class="bi bi-file-earmark text-secondary" style="font-size:1.1rem;"></i> Ekle...</button>
                                        <button type="button" class="btn btn-sm btn-light border-0 bg-white text-muted" title="Klasör oluştur"><i class="bi bi-folder-plus text-secondary" style="font-size:1.1rem;"></i></button>
                                        <button type="button" class="btn btn-sm btn-light border-0 bg-white text-muted" title="İndir"><i class="bi bi-download text-secondary" style="font-size:1.1rem;"></i></button>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <button type="button" class="btn btn-sm btn-light border-0 bg-white view-btn border rounded" title="Simgeleri göster" onclick="toggleViewMode(this, 'grid')"><i class="bi bi-grid-3x3-gap text-secondary" style="font-size:1.1rem;"></i></button>
                                        <button type="button" class="btn btn-sm btn-light border-0 bg-white view-btn" title="Ayrıntıları göster" onclick="toggleViewMode(this, 'list')"><i class="bi bi-list-ul text-secondary" style="font-size:1.1rem;"></i></button>
                                        <button type="button" class="btn btn-sm btn-light border-0 bg-white view-btn" title="Ağacı göster" onclick="toggleViewMode(this, 'tree')"><i class="bi bi-folder text-secondary" style="font-size:1.1rem;"></i></button>
                                    </div>
                                </div>

                                <!-- Dropzone -->
                                <div class="p-4" style="background-color: #fff;">
                                    <div id="fileDropzone" class="d-flex flex-column justify-content-center align-items-center py-5" style="border: 1px dashed #adb5bd !important; cursor: pointer; transition: all 0.2s;" onclick="document.getElementById('videoFile').click()">
                                        <div id="uploadPrompt" class="text-center w-100">
                                            <div class="mb-3">
                                                <i class="bi bi-arrow-down-circle text-muted" style="font-size: 3rem;"></i>
                                            </div>
                                            <p class="m-0" style="font-size: 0.9rem; color: #495057;">Eklemek istediğiniz dosyaları buraya sürükleyip bırakabilirsiniz.</p>
                                        </div>
                                        <div id="fileInfo" class="d-none w-100 px-2">
                                            <!-- Dynamic content goes here based on view mode -->
                                        </div>
                                    </div>
                                    <input type="file" id="videoFile" name="videoFile" accept="video/*" style="display: none;" onchange="handleFileSelect(this)">
                                </div>
                            </div>
                            <div class="mt-2 text-muted" style="font-size: 0.85rem;">
                                En büyük dosya boyutu: 512 MB, en fazla ek dosya sayısı: 20
                            </div>
                        </div>
                    </div>

                    <!-- Hidden inputs to retain required structure for backend if needed -->
<input type="hidden" id="Title" name="Title" value="@(ViewBag.IsEditMode != null && ViewBag.IsEditMode && ViewBag.CurrentVideo != null ? ViewBag.CurrentVideo.Title : $"{DateTime.Now.ToString("dd MMMM yyyy")} tarihli")">

                    <!-- Action Buttons -->
                    <div class="d-flex justify-content-end gap-3 mt-4">
                        <button type="submit" class="btn btn-primary px-4 py-2 fw-medium" style="background-color: #3b71ca; border-color: #3b71ca; border-radius: 4px; font-size: 0.9rem;">Değişiklikleri kaydet</button>
                        <a href="/Student/StudentPage" class="btn btn-outline-primary px-4 py-2 fw-medium bg-white" style="color: #3b71ca; border-color: #3b71ca; border-radius: 4px; font-size: 0.9rem;">İptal</a>
                    </div>
                </form>
                </div>
            </div>
            
            <script>
                let uploadedFile = null;

                function handleFileSelect(input) {
                    const file = input.files[0];
                    if (file) {
                        uploadedFile = {
                            name: file.name,
                            dateStr: new Date(file.lastModified).toLocaleDateString('tr-TR', { day: '2-digit', month: '2-digit', year: '2-digit' }) + ", " + new Date(file.lastModified).toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' }),
                            sizeStr: (file.size / (1024 * 1024)).toFixed(1) + " MB",
                            typeStr: "Video dosyası (MP4)"
                        };
                        
                        document.getElementById('uploadPrompt').classList.add('d-none');
                        document.getElementById('fileInfo').classList.remove('d-none');
                        document.getElementById('fileDropzone').style.border = "none";
                        document.getElementById('fileDropzone').style.backgroundColor = "#fff";
                        document.getElementById('fileDropzone').classList.remove('py-5', 'justify-content-center', 'align-items-center');
                        document.getElementById('fileDropzone').classList.add('p-2');
                        
                        // Set default view (grid)
                        renderView('grid');
                    }
                }
                
                function renderView(mode) {
                    if(!uploadedFile) return;
                    const container = document.getElementById('fileInfo');
                    
                    if(mode === 'grid') {
                        container.innerHTML = `
                            <div class="d-flex flex-column align-items-center" style="width: 120px; text-align: center;">
                                <div class="mb-2" style="font-size: 3rem; color: #343a40;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" fill="currentColor" class="bi bi-file-earmark-play" viewBox="0 0 16 16">
                                      <path d="M6 6.883v4.234a.5.5 0 0 0 .757.429l3.528-2.117a.5.5 0 0 0 0-.858L6.757 6.454a.5.5 0 0 0-.757.43z"/>
                                      <path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2M9.5 3A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5z"/>
                                    </svg>
                                </div>
                                <div class="text-primary text-truncate w-100" style="font-size: 0.9rem;">${uploadedFile.name}</div>
                            </div>
                        `;
                    } else if (mode === 'list') {
                        container.innerHTML = `
                            <table class="table table-borderless table-hover m-0" style="font-size: 0.9rem; color: #495057;">
                                <thead style="border-bottom: 1px solid #dee2e6;">
                                    <tr>
                                        <th style="width: 40px;"></th>
                                        <th>Adı</th>
                                        <th>En son değiştirme</th>
                                        <th>Boyut</th>
                                        <th>Tür</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td class="text-center align-middle"><input class="form-check-input" type="checkbox" style="border-color: #adb5bd;" /></td>
                                        <td class="align-middle">
                                            <i class="bi bi-file-earmark-play text-muted me-2" style="font-size: 1.1rem;"></i> 
                                            <span class="text-primary">${uploadedFile.name}</span>
                                        </td>
                                        <td class="align-middle">${uploadedFile.dateStr}</td>
                                        <td class="align-middle">${uploadedFile.sizeStr}</td>
                                        <td class="align-middle">${uploadedFile.typeStr}</td>
                                    </tr>
                                </tbody>
                            </table>
                        `;
                    } else if (mode === 'tree') {
                        container.innerHTML = `
                            <div style="font-size: 0.9rem; color: #495057;">
                                <div class="d-flex align-items-center mb-2 text-primary" style="margin-left: 5px;">
                                    <i class="bi bi-caret-down-fill me-2" style="font-size: 0.8rem; color: #6c757d;"></i>
                                    <i class="bi bi-folder me-2" style="font-size: 1.1rem;"></i>
                                    Dosyalar
                                </div>
                                <div class="d-flex align-items-center" style="margin-left: 30px;">
                                    <i class="bi bi-file-earmark-play text-muted me-2" style="font-size: 1.1rem;"></i>
                                    <span class="text-primary">${uploadedFile.name}</span>
                                </div>
                            </div>
                        `;
                    }
                }
                
                // Drag and drop support
                const dropzone = document.getElementById('fileDropzone');
                
                dropzone.addEventListener('dragover', (e) => {
                    e.preventDefault();
                    if(!uploadedFile) {
                        dropzone.style.backgroundColor = "#f8f9fa";
                        dropzone.style.borderColor = "#0d6efd";
                    }
                });
                
                dropzone.addEventListener('dragleave', (e) => {
                    e.preventDefault();
                    if(!uploadedFile) {
                        dropzone.style.backgroundColor = "#fff";
                        dropzone.style.borderColor = "#adb5bd";
                    }
                });
                
                dropzone.addEventListener('drop', (e) => {
                    e.preventDefault();
                    if(!uploadedFile) {
                        dropzone.style.backgroundColor = "#fff";
                    }
                    if (e.dataTransfer.files.length) {
                        document.getElementById('videoFile').files = e.dataTransfer.files;
                        handleFileSelect(document.getElementById('videoFile'));
                    }
                });

                function toggleViewMode(btn, mode) {
                    document.querySelectorAll('.view-btn').forEach(b => {
                        b.classList.remove('border', 'border-primary', 'rounded');
                    });
                    btn.classList.add('border', 'border-primary', 'rounded');
                    
                    renderView(mode);
                }
            </script>
        </div>

        <footer class="footer-popover">
            <img src="~/img/footerLogo.png" alt="KTUN Logo" height="80">
            <a class="no-click" href="https://www.ktun.edu.tr/tr/Birim/Iletisim/?brm=ykJ8AXlJAZwqxw4bNyp+VQ=="
                target="_blank" rel="noopener">İletişim</a>
        </footer>
    </div>

    <script src="~/scripts/calendar.js"></script>
    <script src="~/scripts/main.js"></script>
    <script src="~/scripts/diary.js"></script>
    <!-- Video.js -->
    <script src="https://vjs.zencdn.net/7.20.3/video.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- JavaScript Kodları -->



</body>

</html>
