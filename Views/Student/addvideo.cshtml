                                <div class="notification-item">
                                    <div class="notification-content notification-content-ellipsis">
                                        <strong>Konya Teknik Üniversitesi</strong> hesabınızda yeni oturum açın...
                                    </div>
                                    <div class="notification-time">1 saat 20 dk önce</div>
                                    <a href="#" class="view-notification-link">Tam bildirimi görüntüle</a>
                                </div>

                                <div class="notification-item">
                                    <div class="notification-content notification-content-ellipsis">
                                        <strong>Mesleki Staj_SB:0_Yazılım Mühendisliği</strong> 'a hoş geldiniz...
                                    </div>
                                    <div class="notification-time">11 saat 24 dk önce</div>
                                    <a href="#" class="view-notification-link">Tam bildirimi görüntüle</a>
                                </div>

                                <div class="notification-item">
                                    <div class="notification-content notification-content-ellipsis">
                                        <strong>Python Programlama_SB:0_Yazılım Mühendisliği</strong> 'a hoş geldiniz...
                                    </div>
                                    <div class="notification-time">11 saat 26 dk önce</div>
                                    <a href="#" class="view-notification-link">Tam bildirimi görüntüle</a>
                                </div>
                            </div>

                            <a href="#" class="view-all-link">View all notifications</a>
                        </div>
                    </div>

                    <!-- Mesaj İkonu -->
                    <div class="dropdown">
                        <a class="message-icon" href="#" role="button" id="messageDropdown" data-bs-toggle="dropdown"
                            aria-expanded="false">
                            <svg class="svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16">
                                <path
                                    d="M14 1a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H4.414A2 2 0 0 0 3 11.586l-2 2V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12.793a.5.5 0 0 0 .854.353l2.853-2.853A1 1 0 0 1 4.414 12H14a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H3a1 1 0 0 0-1 1v1H1V2a2 2 0 0 1 2-2" />
                            </svg>
                            <span class="message-badge">1</span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end" aria-labelledby="messageDropdown">
                            <div class="notification-header">
                                <h6>Mesajlar</h6>
                            </div>
                            <div class="notification-item">
                                <div class="notification-content">
                                    <strong>Fatma Zehra Solak</strong>: Staj defteriniz incelenmiştir. Lütfen
                                    düzeltmeleri yapınız...
                                </div>
                                <div class="notification-time">2 gün önce</div>
                                <a href="#" class="view-notification-link">Mesajı görüntüle</a>
                            </div>
                            <a href="#" class="view-all-link">Tüm mesajları görüntüle</a>
                        </div>
                    </div>
                </div>

