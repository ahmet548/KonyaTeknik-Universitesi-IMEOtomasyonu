<div class="col-md-12">
    <div class="diary-container">
        @{
            var leaveDetails = ViewBag.LeaveDetails as List<IMEAutomationDBOperations.Models.LeaveDetails>;
            var excusesCount = leaveDetails?.Count ?? 0;
        }

        <!-- Sekmeler / Başlıklar -->
        <h3 style="font-weight: 500;">Mazeret Bildir</h3>
        <h5 class="mt-4 mb-4" style="font-weight: 500;">Mazeretlere genel bakış</h5>

        <!-- İçerik Alanı -->
        <div class="diary-content">
            <!-- Mazeret Formu Sekmesi -->
            <div id="excuse-form-tab" class="diary-tab-content active">
                <div class="diary-layout">
                    <!-- Sol Taraf - Mazeret Formu -->
                    <div class="diary-form-section mb-5">
                        <div class="card info-card border-0 shadow-sm mb-5">
                            <div class="card-body p-4">
                                <h5 class="card-title mb-4" style="color: #2c3e50; font-weight: 600;">Yeni Mazeret Bildirimi</h5>
                                <form method="post" action="/Student/SubmitExcuse">
                                    <div class="row g-4 mt-1">
                                        <!-- Sol Kolon: Tarih ve Mazeret -->
                                        <div class="col-md-7">
                                            <div class="row g-2">
                                                <!-- Başlangıç Tarihi -->
                                                <div class="col-md-6">
                                                    <div class="d-flex align-items-center justify-content-between p-2 border rounded bg-light h-100">
                                                        <label for="LeaveStart" class="form-label text-muted small fw-bold mb-0 me-2" style="font-size: 0.8rem; line-height: 1.2;">Başlangıç Tarihi</label>
                                                        <div class="input-group input-group-sm flex-nowrap" style="width: 140px; flex-shrink: 0;">
                                                            <input type="date" id="LeaveStart" name="LeaveStart" class="form-control text-center px-1" style="border: 1px solid #ced4da; box-shadow: none;" required />
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- Bitiş Tarihi -->
                                                <div class="col-md-6">
                                                    <div class="d-flex align-items-center justify-content-between p-2 border rounded bg-light h-100">
                                                        <label for="LeaveEnd" class="form-label text-muted small fw-bold mb-0 me-2" style="font-size: 0.8rem; line-height: 1.2;">Bitiş Tarihi</label>
                                                        <div class="input-group input-group-sm flex-nowrap" style="width: 140px; flex-shrink: 0;">
                                                            <input type="date" id="LeaveEnd" name="LeaveEnd" class="form-control text-center px-1" style="border: 1px solid #ced4da; box-shadow: none;" required />
                                                        </div>
                                                    </div>
                                                </div>
                                                <!-- Mazeret Türü Dropdown -->
                                                <div class="col-md-12">
                                                    <div class="d-flex align-items-center justify-content-between p-2 border rounded bg-light h-100">
                                                        <label for="LeaveReason" class="form-label text-muted small fw-bold mb-0 me-2" style="font-size: 0.8rem; line-height: 1.2;">Mazeret Türü</label>
                                                        <div class="input-group input-group-sm flex-nowrap" style="width: 250px; flex-shrink: 0;">
                                                            <select id="LeaveReason" name="LeaveReason" class="form-select px-1" style="border: 1px solid #ced4da; box-shadow: none;" required>
                                                                <option value="" disabled selected>Seçiniz...</option>
                                                                <option value="Alttan kalan derslerin vize ve final sınavları">Alttan kalan derslerin vize ve final sınavları</option>
                                                                <option value="ÖSYM Sınavları">ÖSYM Sınavları</option>
                                                                <option value="Hastalık ve sağlık problemleri">Hastalık ve sağlık problemleri</option>
                                                                <option value="Ailevi sebepler">Ailevi sebepler</option>
                                                                <option value="Diğer Mazeretler">Diğer Mazeretler</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Sağ Kolon: Açıklama ve Adres -->
                                        <div class="col-md-5 d-flex flex-column gap-3">
                                            <div class="d-flex flex-column flex-grow-1">
                                                <label for="ReasonDetail" class="form-label text-muted small fw-bold mb-1" style="font-size: 0.8rem;">Mazeret Açıklaması</label>
                                                <textarea id="ReasonDetail" name="ReasonDetail" class="form-control form-control-sm bg-light flex-grow-1" style="min-height: 120px; resize: none; font-size: 14px; padding: 12px; border: 2px solid #fff;" placeholder="Mazeretinizi detaylı bir şekilde açıklayın..." required></textarea>
                                            </div>

                                            <div class="d-flex flex-column">
                                                <label for="AddressDuringLeave" class="form-label text-muted small fw-bold mb-1" style="font-size: 0.8rem;">İzin Süresince Bulunacağı Adres</label>
                                                <textarea id="AddressDuringLeave" name="AddressDuringLeave" class="form-control form-control-sm bg-light" style="min-height: 80px; resize: none; font-size: 14px; padding: 12px; border: 2px solid #fff;" placeholder="İzin süresince bulunacağınız tam adresi yazın..." required></textarea>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Alt Butonlar -->
                                    <div class="mt-4 d-flex justify-content-end align-items-center pt-3 border-top">
                                        <button type="submit" class="btn text-white px-5 py-2" style="background-color: #4674C1; font-weight: 600; font-size: 14px; border-radius: 4px;">Gönder</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Sağ Taraf - Mazeret Geçmişi -->
                    <div class="diary-history-section">
                        <div class="excuse-history-header">
                            <h5 class="excuse-history-title">Mazeret Geçmişim</h5>
                        </div>

                        <div class="diary-history-list">
                            @if (leaveDetails != null && leaveDetails.Any())
                            {
                                foreach (var excuse in leaveDetails)
                                {
                                    <div class="diary-history-card excuse-card" id="excuse-card-@excuse.LeaveID">
                                        <!-- Kart Header -->
                                        <div class="diary-history-card-header">
                                            <!-- 3 nokta menü butonu -->
                                            <button class="diary-history-card-menu" onclick="toggleExcuseMenu(@excuse.LeaveID)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11"
                                                    fill="currentColor" class="bi bi-three-dots" viewBox="0 0 16 16">
                                                    <path
                                                        d="M3 9.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3" />
                                                </svg>
                                            </button>

                                            <!-- Dropdown menü -->
                                            <div class="diary-history-dropdown" id="excuse-dropdown-@excuse.LeaveID">
                                                @if (excuse.LeaveStatus == "Onay Bekliyor")
                                                {
                                                    <button class="diary-history-dropdown-item text-danger"
                                                        onclick="deleteExcuse(@excuse.LeaveID)">
                                                        Mazereti Sil
                                                    </button>
                                                }
                                                <a href="/Home/MazeretIzinFormu?leaveId=@excuse.LeaveID" target="_blank"
                                                    class="diary-history-dropdown-item">
                                                    Belgeyi İndir
                                                </a>
                                            </div>

                                            <!-- Status badge -->
                                            <div class="excuse-status-container">
                                                <span
                                                    class="excuse-status-badge @(excuse.LeaveStatus == "Onay Bekliyor" ? "status-pending" : "")">
                                                    @excuse.LeaveStatus
                                                </span>
                                            </div>

                                            <h6 class="diary-history-card-title">@excuse.LeaveReason</h6>
                                            <span class="diary-history-card-date">
                                                @excuse.LeaveStart.ToString("dd.MM.yyyy") -
                                                @excuse.LeaveEnd.ToString("dd.MM.yyyy")
                                            </span>
                                        </div>

                                        <!-- Mazeret Açıklaması -->
                                        <div class="diary-history-card-content">
                                            @excuse.ReasonDetail
                                        </div>

                                        <!-- Adres Bilgisi -->
                                        @if (!string.IsNullOrEmpty(excuse.AddressDuringLeave))
                                        {
                                            <div class="excuse-address">
                                                <small class="text-muted">
                                                    <i class="fas fa-map-marker-alt me-1"></i>
                                                    @excuse.AddressDuringLeave
                                                </small>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="diary-history-empty text-center py-5">
                                    <img class="empty-placeholder-image-lg mt-1"
                                        src="https://lms.ktun.edu.tr/theme/image.php/remui/block_myoverview/1757327541/courses"
                                        style="width:110px; margin-bottom: 15px;" alt="">
                                    <p class="text-muted">Henüz hiç mazeretiniz bulunmamaktadır.</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
